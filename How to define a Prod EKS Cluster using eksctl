apiVersion: eksctl.io/v1alpha5
kind: ClusterConfig
metadata:
  name: staging-x
  region: us-east-1
  version: "1.35"
vpc:
  cidr: 11.0.0.0/16
  nat:
    gateway: Single or HighlyAvailable
  clusterEndpoints:
    publicAccess: true
    privateAccess: true
availabilityZones: ["us-east-1a", "us-east-1b", "us-east-1c"]
managedNodeGroups:
  - name: staging-x-nodes
    privateNetworking: true
    desiredCapacity: 2
    minSize: 2
    maxSize: 2
    instanceTypes: ["m5.large"]
    amiFamily: AmazonLinux2023
    labels: { role: worker }
    tags:
      Name: staging-x-ng-1
